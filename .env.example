# Required for Databricks CLI (bundles)
DATABRICKS_HOST="https://<your-workspace-url>"
DATABRICKS_TOKEN="<your-pat-token>"

# Bundle variable: SQL warehouse ID (SQL Warehouses → warehouse → Overview)
BUNDLE_VAR_warehouse_id="<warehouse-id>"

# GitHub Actions: store the same warehouse id as repo secret BUNDLE_VAR_WAREHOUSE_ID
