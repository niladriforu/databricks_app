# Required for Databricks CLI (bundles)
DATABRICKS_HOST="https://<your-workspace-url>"
DATABRICKS_TOKEN="<your-pat-token>"

# Existing cluster for spark_python_task (Compute → cluster → ID in URL or UI)
BUNDLE_VAR_cluster_id="<cluster-id>"

# GitHub Actions: same value as repo secret BUNDLE_VAR_CLUSTER_ID
